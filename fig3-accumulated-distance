from pathlib import Path
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd

def label_bouts(path):
    df = pd.read_hdf(path, key="analysed")
    return df[(df.index.get_level_values('window_time') > 10) &
              (df.index.get_level_values('window_time') < 30)]


def group_df_by_trial_total_distance(df):
    return df.groupby(["folder_name", "stimulus_name"])["distance_change"].sum()


def get_fish_level_totals(series, filter_str):
    fish_vals = {}
    for (fish, stimulus), value in series.items():
        if filter_str in stimulus:
            fish_vals.setdefault(fish, []).append(value)
    return [np.nanmean(vals) for vals in fish_vals.values()]



path1 = Path()
path2 = Path()
path_to_output_folder = Path()


all_values_folder = path_to_output_folder / "all-values"
all_values_folder.mkdir(parents=True, exist_ok=True)

datasets = {
    "WT": path1,
    r"$\it{adgrl3.1}^{-/-}$": path2
}
contrast_filters = ['_0.25_', '_0.75_']


all_data = []
for contrast in contrast_filters:
    for group_name, path in datasets.items():
        df = group_df_by_trial_total_distance(label_bouts(path))
        vals = get_fish_level_totals(df, contrast)
        for i, v in enumerate(vals):
            all_data.append({
                "Group": group_name,
                "Contrast": contrast.strip('_'),
                "FishID": f"{group_name}_Fish{i + 1}",
                "Value_mm": v
            })

df_output = pd.DataFrame(all_data)
csv_output_path = all_values_folder / "total_distance_all_values.csv"
df_output.to_csv(csv_output_path, index=False)


colors_low = {
    "WT": "plum", 
    r"$\it{adgrl3.1}^{-/-}$": "skyblue"}
colors_high = {
    "WT": "rebeccapurple",
    r"$\it{adgrl3.1}^{-/-}$": "cornflowerblue"}
fig, axs = plt.subplots(1, 2, figsize=(12, 6))

for i, contrast in enumerate(contrast_filters):
    ax = axs[i]
    group_means = []
    group_sems = []
    all_fish_vals = []

    for name, path in datasets.items():
        df = group_df_by_trial_total_distance(label_bouts(path))
        fish_vals = get_fish_level_totals(df, contrast)
        all_fish_vals.append(fish_vals)

        mean_val = np.nanmean(fish_vals)
        sem_val = np.nanstd(fish_vals) / np.sqrt(len(fish_vals))

        group_means.append(mean_val)
        group_sems.append(sem_val)

    x = np.arange(len(datasets))
    color_map = colors_low if contrast == '_0.25_' else colors_high

    #Bars
    ax.bar(
        x, group_means, yerr=group_sems, capsize=8,
        color=[color_map[name] for name in datasets.keys()],
        edgecolor='black', linewidth=2,
        error_kw=dict(elinewidth=2.5, capthick=2.5)
    )
    #indiviudal points
    for xi, vals in zip(x, all_fish_vals):
        ax.scatter(
            np.full_like(vals, xi, dtype=float), vals,
            facecolor='black', edgecolor='black',
            zorder=10, s=50, linewidths=2, alpha=0.3
        )

    ax.set_xticks(x)
    ax.set_xticklabels(list(datasets.keys()), fontsize=18)
    ax.set_ylabel("Total distance swam (mm)", fontsize=20)
    ax.set_title(f"{contrast.strip('_')} Contrast", fontsize=20)
    ax.spines['right'].set_visible(False)
    ax.spines['top'].set_visible(False)
    ax.spines['left'].set_linewidth(1.5)
    ax.spines['bottom'].set_linewidth(1.5)
    ax.tick_params(axis='y', labelsize=18)
    ax.set_ylim(0, 30)
    ax.set_yticks([0, 5, 10, 15, 20, 25, 30])
    ax.set_yticklabels(['0', '300', '600', '900', '1200', '1500', '1800'], fontsize=18)

plt.tight_layout()
plt.subplots_adjust(wspace=0.3)
plt.savefig(path_to_output_folder / 'total_accumulated_distance_individuals.svg', format='svg')
plt.savefig(path_to_output_folder / 'total_accumulated_distance_individuals.jpg', format='jpg')
plt.show()

