def plotting_func(x, y, e, stimuli, name_of_dataset, color_of_plot, ax, ylabel, hide_xaxis=False, ylim_max=0.5, y_ticks=None):
    ax.errorbar(x, y, yerr=e, fmt='o', color=color_of_plot, linewidth=3)
    ax.scatter(x, y, marker=".", color=color_of_plot, s=100, linewidths=2.5)
    ax.set_xticks(x)
    ax.set_xticklabels(['0.6', '1.3', '2.6', '5.1', '10.3', '20.6', '41.1'], fontsize=14)
    if hide_xaxis:
        ax.set_xlabel('')
        ax.tick_params(axis='x', which='both', bottom=False, top=False, labelbottom=False)
        ax.spines['bottom'].set_visible(False)
    else:
        ax.set_xlabel("Stripe width (mm)", fontsize=18)
        ax.spines['bottom'].set_linewidth(2)
        ax.tick_params(axis='x', labelbottom=True)
    ax.set_ylabel(ylabel, fontsize=18)
    ax.spines['right'].set_color('none')
    ax.spines['top'].set_color('none')
    ax.spines['left'].set_linewidth(2)
    if not hide_xaxis:
        ax.spines['bottom'].set_linewidth(1.5)
    ax.set_ylim(0, ylim_max)
    if y_ticks is None:
        y_ticks = np.linspace(0, ylim_max, num=6)
    ax.set_yticks(y_ticks)
    ax.set_yticklabels([f"{tick:.1f}" for tick in y_ticks], fontsize=18)

