def label_bouts(path):
    df = pd.read_hdf(path, key="analysed")
    return df[(df.index.get_level_values('window_time') > 10) &
              (df.index.get_level_values('window_time') < 30)]

def compute_ibi_cv_per_fish(df):
    grouped = df.groupby(['folder_name', 'stimulus_name'])
    ibi_cv_list = []

    for (fish, stim), group in grouped:
        # times = group['interbout_interval'].values
        times = group.index.get_level_values('window_time').values
        if len(times) > 1:
            ibi = np.diff(times)
            mean_ibi = np.nanmean(ibi)
            if mean_ibi > 0:
                cv = np.nanstd(ibi) / mean_ibi
                ibi_cv_list.append({'folder_name': fish, 'stimulus_name': stim, 'ibi_cv': cv})
    return pd.DataFrame(ibi_cv_list)



def compute_speed_cv_per_fish(df):
    grouped = df.groupby(['folder_name', 'stimulus_name'])
    speed_cv_list = []

    for (fish, stim), group in grouped:
        speeds = group['average_speed'].values
        mean_speed = np.nanmean(speeds)
        if mean_speed > 0:
            cv = np.nanstd(speeds) / mean_speed
            speed_cv_list.append({'folder_name': fish, 'stimulus_name': stim, 'speed_cv': cv})
    return pd.DataFrame(speed_cv_list)


def aggregate_cv(df_cv, colname):
    grouped = df_cv.groupby('stimulus_name')[colname]
    means = grouped.mean()
    sems = grouped.apply(sem)
    return means, sems

def extract_means_and_sems(means, sems, filter_str):
    filtered_stimuli = [stim for stim in means.index if filter_str in stim]
    x = np.arange(len(filtered_stimuli))
    y = [means[stim] for stim in filtered_stimuli]
    e = [sems[stim] for stim in filtered_stimuli]
    return x, y, e, filtered_stimuli


